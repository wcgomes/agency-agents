{
  "id": "agency-agents",
  "version": "0.1.0",
  "name": "Agency Agents",
  "description": "Downloads agency-agents as ZIP and runs convert/install for a selected tool.",
  "documentationURL": "https://github.com/msitarzewski/agency-agents",
  "options": {
    "tool": {
      "type": "string",
      "default": "copilot",
      "description": "Tool name passed to ./scripts/install.sh --tool <tool>."
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}
