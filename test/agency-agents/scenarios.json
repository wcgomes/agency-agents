{
    "default_auto": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {}
        }
    },
    "explicit_copilot": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "copilot"
            }
        }
    },
    "explicit_all": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "all"
            }
        }
    }
}
