{
    "default_auto": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {}
        }
    },
    "explicit_copilot": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "copilot"
            }
        }
    },
    "explicit_all": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "all"
            }
        }
    },
    "explicit_opencode": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "opencode"
            }
        }
    },
    "autoupdate_disabled": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "auto",
                "autoupdate": false
            }
        }
    },
    "autoupdate_enabled": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agency-agents": {
                "tool": "auto",
                "autoupdate": true
            }
        }
    }
}
