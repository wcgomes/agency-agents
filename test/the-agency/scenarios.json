{
    "default_auto": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "the-agency": {}
        }
    },
    "explicit_copilot": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "the-agency": {
                "tool": "copilot"
            }
        }
    },
    "explicit_all": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "the-agency": {
                "tool": "all"
            }
        }
    },
    "use_agent_zero_enabled": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "the-agency": {
                "tool": "copilot",
                "use-agent-zero": true
            }
        }
    }
}
